generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id
  name                  String
  email                 String                 @unique
  emailVerified         Boolean
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  stripeCustomerId      String?
  sessions              Session[]
  accounts              Account[]
  shopifyStores         ShopifyStore[]
  subscriptions         Subscription[]
  googleBusinessAccount GoogleBusinessAccount?
  reviewAccounts        ReviewAccount[]
  feedbacks              Feedback[]
  globalStyles            GlobalStyles?
  reviewPageCustomization     ReviewPageCustomization?
  redirectionPageCustomization RedirectionPageCustomization?
  feedbackPageCustomization   FeedbackPageCustomization?
  userCampaigns         UserCampaign[]

  @@map("user")
}

model GlobalStyles {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandLogoUrl        String?
  font                String?   @default("inter")
  cornerRoundness     String?  @default("md")
  buttonCornerRoundness String? @default("md")
  borderColor         String?  @default("#000000")
  buttonBgColor       String?  @default("#000000")
  buttonTextColor     String?  @default("#FFFFFF")
  starsColor          String?  @default("#FFD230")
  bgColor             String?  @default("#FFFFFF")
  textColor           String?  @default("#000000")
  cardColor           String?  @default("#FFFFFF")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("global_styles")
}

model ReviewPageCustomization {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?  @default("How would you rate your experience?")
  ratingTemplate  String?  @default("classic") // "arc-stars" | "classic"
  buttonText      String?  @default("Continue")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("review_page_customization")
}

model RedirectionPageCustomization {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String?  @default("Thank you for your feedback!")
  buttonText         String?  @default("Continue")
  description        String?  @default("You will be redirected to review platforms to share your experience.")
  descriptionEnabled Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("redirection_page_customization")
}

model FeedbackPageCustomization {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                String?  @default("How would you rate your experience?")
  helpText             String?  @default("Share your experience to help us improve.")
  helpTextEnabled      Boolean  @default(true)
  reviewTag            String?  @default("What is the main subject of your feedback?")
  reviewTagEnabled     Boolean  @default(true)
  reviewTagOptions     Json?    // string[] : liste de sujets (ex. Qualité du produit, Livraison, …)
  reviewTitle          String?  @default("Give a title to your review")
  reviewTitleEnabled   Boolean  @default(true)
  reviewComment        String?  @default("Leave a comment")
  reviewCommentEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("feedback_page_customization")
}

model Subscription {
  id                   String    @id
  plan                 String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String?
  periodStart          DateTime?
  periodEnd            DateTime?
  cancelAtPeriodEnd    Boolean?
  cancelAt             DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  seats                Int?
  trialStart           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User?     @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@index([referenceId])
  @@index([stripeCustomerId])
  @@map("subscription")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model ShopifyStore {
  id                   String               @id @default(cuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop                 String               @unique // "ma-boutique.myshopify.com"
  accessToken          String               // Token d'accès Shopify
  scope                String               // Scopes accordés
  orderReviewRequests  OrderReviewRequest[]
  userCampaigns        UserCampaign[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
  @@map("shopify_store")
}

// ============ CAMPAIGNS ============
// Campaigns are defined in code (lib/campaigns.ts). UserCampaign stores user config per store.

/** Activation + config par utilisateur, par store. */
model UserCampaign {
  id            String         @id @default(cuid())
  userId        String
  campaignSlug  String         // "order_review_request" - from campaigns config in code
  storeId       String         // Campaign activated per store
  status        String         @default("active") // active | inactive
  triggerType   String         @default("purchase") // purchase | shipment | receipt
  delayHours    Int            @default(24)
  channel       String         // "whatsapp" | "sms" | "email"
  messageContent       String?  // WhatsApp/SMS template content, personalization
  thanksMessageEnabled Boolean  @default(true) // Show thank-you message after customer leaves review
  thanksMessageContent String?   // Custom message shown after review submission
  activatedAt          DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  store    ShopifyStore  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, campaignSlug])
  @@index([userId])
  @@index([campaignSlug])
  @@index([storeId])
  @@map("user_campaign")
}

model RateLimit {
  id          String   @id
  key         String   @unique
  count       Int
  lastRequest BigInt

  @@map("rateLimit")
}

model GoogleBusinessAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String   // "accounts/123456789"
  accountName  String   // Nom du compte Business
  locationId   String?  // "locations/123456789" (si une seule location)
  locationName String?  // Nom de l'établissement
  accessToken  String   // Token d'accès Google
  refreshToken String?  // Token de rafraîchissement
  expiresAt    DateTime // Expiration du token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_business_account")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageUrl   String   // URL de la page où le bouton a été cliqué
  message   String   // Contenu du feedback (max 1024 caractères)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("feedback")
}

/** Demande d'avis programmée après une commande Shopify (étape B → QStash). */
model OrderReviewRequest {
  id              String        @id @default(cuid())
  storeId         String        // Boutique Shopify qui a reçu la commande
  store           ShopifyStore  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopifyOrderId  String        // ID Shopify de la commande (pour retrouver la commande)
  customerPhone   String?
  customerEmail   String?
  customerFirstName String?     // For {{customer_first_name}} in message template (from order)
  channel         String        @default("email") // "whatsapp" | "sms" | "email" - from UserCampaign
  scheduledAt     DateTime      // Heure à laquelle QStash doit appeler /api/send-review-message
  status          String        @default("pending") // pending | sent | failed
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([storeId, shopifyOrderId])
  @@index([storeId])
  @@index([status])
  @@map("order_review_request")
}

// ============ REVIEWS (TRUSTPILOT + GOOGLE) ============

enum ReviewSource {
  TRUSTPILOT
  GOOGLE
}

/** Compte connecté pour récupérer des avis (Trustpilot ou Google Maps) */
model ReviewAccount {
  id                  String        @id @default(cuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  source              ReviewSource  // TRUSTPILOT | GOOGLE
  sourceId            String        // Domaine Trustpilot ou placeId Google
  name                String?       // Nom entreprise / lieu
  businessUrl         String?
  isConnected         Boolean       @default(true)
  trustScore          Float?
  totalReviews        Int?
  profileImageUrl     String?
  statsTotal          Int?
  statsOne            Int?
  statsTwo            Int?
  statsThree          Int?
  statsFour           Int?
  statsFive           Int?
  lastSyncAt          DateTime?
  lastDomainChangeAt  DateTime?
  sourceMetadata      Json?         // Données spécifiques (address, placeId...)
  syncs               ReviewSync[]
  reviews             Review[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([userId, source])
  @@index([userId])
  @@map("review_account")
}

/** Job de synchronisation Apify (Trustpilot ou Google) */
model ReviewSync {
  id             String       @id @default(cuid())
  accountId      String
  account        ReviewAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  apifyRunId     String?
  apifyDatasetId String?
  status         String       @default("PENDING")
  error          String?
  reviewsCount   Int?
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?

  @@index([accountId])
  @@index([status])
  @@map("review_sync")
}

/** Avis stockés (Trustpilot ou Google Maps) */
model Review {
  id                String       @id @default(cuid())
  accountId         String
  account           ReviewAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  source            ReviewSource  // Dénormalisé pour filtrage
  sourceId          String        // trustpilotId ou reviewId
  rating            Int           // Note (1-5)
  title             String?       // Trustpilot uniquement
  text              String?
  language          String?
  authorName        String?
  authorImageUrl    String?
  authorCountry     String?       // Code ISO (FR, US...)
  isVerified        Boolean      @default(false) // Trustpilot: vérifié | Google: Local Guide
  experiencedAt     DateTime?
  publishedAt       DateTime?
  replyText         String?
  replyPublishedAt  DateTime?
  reviewUrl         String?       // Lien vers l'avis
  sourceMetadata    Json?         // reviewImageUrls, textTranslated, likesCount...
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([accountId, sourceId])
  @@index([accountId])
  @@index([source])
  @@index([rating])
  @@index([publishedAt])
  @@map("review")
}
