generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id
  name                  String
  email                 String                 @unique
  emailVerified         Boolean
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  stripeCustomerId      String?
  sessions              Session[]
  accounts              Account[]
  shopifyStores         ShopifyStore[]
  subscriptions         Subscription[]
  googleBusinessAccount GoogleBusinessAccount?
  trustpilotAccount     TrustpilotAccount?
  feedbacks              Feedback[]
  globalStyles            GlobalStyles?
  reviewPageCustomization     ReviewPageCustomization?
  redirectionPageCustomization RedirectionPageCustomization?
  feedbackPageCustomization   FeedbackPageCustomization?

  @@map("user")
}

model GlobalStyles {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandLogoUrl        String?
  font                String?   @default("inter")
  cornerRoundness     String?  @default("md")
  buttonCornerRoundness String? @default("md")
  borderColor         String?  @default("#000000")
  buttonBgColor       String?  @default("#000000")
  buttonTextColor     String?  @default("#FFFFFF")
  starsColor          String?  @default("#FFD230")
  bgColor             String?  @default("#FFFFFF")
  textColor           String?  @default("#000000")
  cardColor           String?  @default("#FFFFFF")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("global_styles")
}

model ReviewPageCustomization {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?  @default("How would you rate your experience?")
  ratingTemplate  String?  @default("classic") // "arc-stars" | "classic"
  buttonText      String?  @default("Continue")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("review_page_customization")
}

model RedirectionPageCustomization {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String?  @default("Thank you for your feedback!")
  buttonText         String?  @default("Continue")
  description        String?  @default("You will be redirected to review platforms to share your experience.")
  descriptionEnabled Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("redirection_page_customization")
}

model FeedbackPageCustomization {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                String?  @default("How would you rate your experience?")
  helpText             String?  @default("Share your experience to help us improve.")
  helpTextEnabled      Boolean  @default(true)
  reviewTag            String?  @default("What is the main subject of your feedback?")
  reviewTagEnabled     Boolean  @default(true)
  reviewTagOptions     Json?    // string[] : liste de sujets (ex. Qualité du produit, Livraison, …)
  reviewTitle          String?  @default("Give a title to your review")
  reviewTitleEnabled   Boolean  @default(true)
  reviewComment        String?  @default("Leave a comment")
  reviewCommentEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("feedback_page_customization")
}

model Subscription {
  id                   String    @id
  plan                 String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String?
  periodStart          DateTime?
  periodEnd            DateTime?
  cancelAtPeriodEnd    Boolean?
  cancelAt             DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  seats                Int?
  trialStart           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User?     @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@index([referenceId])
  @@index([stripeCustomerId])
  @@map("subscription")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model ShopifyStore {
  id                   String               @id @default(cuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop                 String               @unique // "ma-boutique.myshopify.com"
  accessToken          String               // Token d'accès Shopify
  scope                String               // Scopes accordés
  orderReviewRequests  OrderReviewRequest[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
  @@map("shopify_store")
}

model RateLimit {
  id          String   @id
  key         String   @unique
  count       Int
  lastRequest BigInt

  @@map("rateLimit")
}

model GoogleBusinessAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String   // "accounts/123456789"
  accountName  String   // Nom du compte Business
  locationId   String?  // "locations/123456789" (si une seule location)
  locationName String?  // Nom de l'établissement
  accessToken  String   // Token d'accès Google
  refreshToken String?  // Token de rafraîchissement
  expiresAt    DateTime // Expiration du token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_business_account")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageUrl   String   // URL de la page où le bouton a été cliqué
  message   String   // Contenu du feedback (max 1024 caractères)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("feedback")
}

/** Demande d'avis programmée après une commande Shopify (étape B → QStash). */
model OrderReviewRequest {
  id              String        @id @default(cuid())
  storeId         String        // Boutique Shopify qui a reçu la commande
  store           ShopifyStore  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopifyOrderId  String        // ID Shopify de la commande (pour retrouver la commande)
  customerPhone   String?
  customerEmail   String?
  scheduledAt     DateTime      // Heure à laquelle QStash doit appeler /api/send-review-message
  status          String        @default("pending") // pending | sent | failed
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([storeId, shopifyOrderId])
  @@index([storeId])
  @@index([status])
  @@map("order_review_request")
}

// ============ TRUSTPILOT INTEGRATION ============

/** Compte Trustpilot connecté par l'utilisateur */
model TrustpilotAccount {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessUrl         String             // URL Trustpilot (ex: "https://trustpilot.com/review/example.com")
  businessDomain      String             // Domaine (ex: "example.com")
  isConnected         Boolean            @default(true) // false = déconnecté mais données conservées
  companyName         String?            // Nom de l'entreprise
  trustScore          Float?             // Score Trustpilot (ex: 4.8)
  totalReviews        Int?               // Nombre total d'avis sur Trustpilot
  profileImageUrl     String?            // Logo de l'entreprise
  // Stats originales Trustpilot (distribution des étoiles)
  statsTotal          Int?               // Total des avis (stats.total)
  statsOne            Int?               // Nombre d'avis 1 étoile
  statsTwo            Int?               // Nombre d'avis 2 étoiles
  statsThree          Int?               // Nombre d'avis 3 étoiles
  statsFour           Int?               // Nombre d'avis 4 étoiles
  statsFive           Int?               // Nombre d'avis 5 étoiles
  lastSyncAt          DateTime?          // Dernière synchronisation réussie
  lastDomainChangeAt  DateTime?          // Dernier changement de domaine (limite: 1x/mois)
  syncs               TrustpilotSync[]
  reviews             TrustpilotReview[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("trustpilot_account")
}

/** Job de synchronisation Apify pour récupérer les avis Trustpilot */
model TrustpilotSync {
  id                String            @id @default(cuid())
  accountId         String
  account           TrustpilotAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  apifyRunId        String?           // ID du run Apify
  apifyDatasetId    String?           // ID du dataset Apify (pour récupérer les résultats)
  status            String            @default("PENDING") // PENDING, RUNNING, SUCCEEDED, FAILED
  error             String?           // Message d'erreur si échec
  reviewsCount      Int?              // Nombre d'avis récupérés
  startedAt         DateTime          @default(now())
  finishedAt        DateTime?

  @@index([accountId])
  @@index([status])
  @@map("trustpilot_sync")
}

/** Avis Trustpilot stockés localement */
model TrustpilotReview {
  id                String            @id @default(cuid())
  accountId         String
  account           TrustpilotAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  trustpilotId      String            // ID unique Trustpilot de l'avis
  rating            Int               // Note (1-5)
  title             String?           // Titre de l'avis
  text              String?           // Contenu de l'avis
  language          String?           // Langue de l'avis
  authorName        String?           // Nom de l'auteur
  authorCountry     String?           // Pays de l'auteur
  isVerified        Boolean           @default(false) // Avis vérifié
  experiencedAt     DateTime?         // Date de l'expérience
  publishedAt       DateTime?         // Date de publication
  replyText         String?           // Réponse de l'entreprise
  replyPublishedAt  DateTime?         // Date de la réponse
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([accountId, trustpilotId])
  @@index([accountId])
  @@index([rating])
  @@index([publishedAt])
  @@map("trustpilot_review")
}
